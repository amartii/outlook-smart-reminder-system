# Outlook Smart Reminder System — Accenture
# Copia este archivo a .env y rellena los valores

# Flask
SECRET_KEY=cambia-esto-en-produccion

# Azure AD (obtener en portal.azure.com)
OUTLOOK_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OUTLOOK_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OUTLOOK_CLIENT_SECRET=tu-client-secret-aqui

# Scheduler (opcional, valores por defecto)
SYNC_CONTACTS_INTERVAL_HOURS=6
CHECK_RESPONSES_INTERVAL_MINUTES=15
SEND_REMINDERS_INTERVAL_HOURS=1
